{
  "name": "OK School Life",
  "version": "1.0.0",
  "description": "",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "start": "node scripts/patch_aiot_toolkit_ignore_pref.cjs && aiot server --watch",
    "build": "aiot build",
    "release": "aiot release--enable-jsc",
    "watch": "node scripts/patch_aiot_toolkit_ignore_pref.cjs && aiot watch",
    "lint": "eslint --fix \"src/**/*.{js,ux}\""
  },
  "lint-staged": {
    "*.{ux,js}": [
      "prettier --write",
      "eslint --fix",
      "git add"
    ],
    "*.{less,css}": [
      "prettier --write",
      "stylelint --fix --custom-syntax postcss-less",
      "git add"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.6",
    "@babel/eslint-parser": "^7.28.6",
    "@commitlint/cli": "^17.3.0",
    "@commitlint/config-conventional": "^17.3.0",
    "@eslint/js": "^9.39.2",
    "aiot-toolkit": "2.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-node": "^0.3.7",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^17.0.0",
    "husky": "^8.0.1",
    "less": "^3.12.2",
    "less-loader": "^6.2.0",
    "lint-staged": "^15.2.0",
    "postcss-html": "^1.3.0",
    "postcss-less": "^6.0.0",
    "prettier": "^3.0.0",
    "stylelint": "^14.5.3",
    "stylelint-config-recess-order": "^3.0.0",
    "stylelint-config-standard": "^25.0.0",
    "stylelint-order": "^5.0.0",
    "ux-types": "^0.1.1"
  },
  "dependencies": {
    "@aiot-toolkit/jsc": "^1.0.8"
  }
}
