{
  "package": "cn.waijade.okschoollife",
  "name": "OK School Life",
  "versionName": "1.0.0",
  "versionCode": 9,
  "minPlatformVersion": 1000,
  "icon": "/common/assets/icon/icon-v4-final.png",
  "deviceTypeList": [
    "watch"
  ],
  "features": [
    {
      "name": "system.router"
    },
    {
      "name": "system.prompt"
    },
    {
      "name": "system.app"
    },
    {
      "name": "system.storage"
    },
    {
      "name": "system.device"
    }
  ],
  "config": {
    "logLevel": "log",
    "designWidth": "device-width"
  },
  "permissions": [
    {
      "name": "hapjs.permission.DEVICE_INFO"
    }
  ],
  "resources": {
    "files": [
      "$src/common/data/events.json",
      "$src/common/data/sentences.json"
    ]
  },
  "router": {
    "entry": "pages/entry",
    "pages": {
      "pages/entry": {
        "component": "entry"
      },
      "pages/index": {
        "component": "index"
      },
      "pages/main": {
        "component": "main"
      },
      "pages/achievement": {
        "component": "achievement"
      },
      "pages/about": {
        "component": "about"
      },
      "pages/donation": {
        "component": "donation"
      },
      "pages/setting": {
        "component": "setting"
      }
    }
  }
}
