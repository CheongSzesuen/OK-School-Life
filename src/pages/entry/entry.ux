    margin: 18px 0;
  }

  .game-name {
    font-size: 52px;
  }

  .loading-text {
    font-size: 34px;
    margin-top: 26px;
  }
}

@media (width: 160) {
  .entry-page {
    padding: 20px;
  }

  .icon {
    border-radius: 30px;
    margin-bottom: 40px;
  }

  .game-name-container {
