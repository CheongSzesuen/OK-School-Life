  margin: 20px 0;
}

.game-name-container {
  width: 100%;
  padding: 0 15px;
  margin: 20px 0;
  justify-content: center;
  align-items: center;
}

.game-name {
  font-size: 55px;
  color: #ffffff;
  font-weight: bold;
  text-align: center;
  width: 100%;
  text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
}

.loading-text {
  font-size: 40px;
  color: #b4ffba;
  animation: blink 1.5s infinite;
  margin-top: 30px;
  text-align: center;
  width: 100%;
  letter-spacing: 2px;
}

@keyframes blink {
  0%,
  100% {
    opacity: 0.7;
  }

  50% {
    opacity: 1;
  }
}

@media (width: 106) {
  .entry-page {
    padding: 8px;
  }

  .icon {
    width: 190px;
    height: 190px;
    border-radius: 38px;
    margin: 18px 0;
  }

